{
  "name": "argo-cd-action",
  "version": "0.0.0",
  "private": true,
  "description": "GitHub action for executing Argo CD",
  "keywords": [
    "github",
    "actions",
    "argo-cd",
    "git-ops"
  ],
  "homepage": "https://github.com/clowdhaus/argo-cd-action#readme",
  "bugs": {
    "url": "https://github.com/clowdhaus/argo-cd-action/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clowdhaus/argo-cd-action.git"
  },
  "license": "Apache-2.0",
  "author": "Clowd Haus, LLC",
  "main": "src/index.ts",
  "scripts": {
    "all": "npm run lint && npm run test && npm run compile",
    "test": "vitest run",
    "compile": "esbuild src/index.ts --bundle --platform=node --target=node24 --minify --outfile=dist/index.js",
    "lint": "eslint . --quiet --fix"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/tool-cache": "^4.0.0",
    "@octokit/auth-action": "^6.0.2",
    "@octokit/rest": "^22.0.1",
    "string-argv": "^0.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.1"
  }
}
